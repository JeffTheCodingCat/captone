@page "/"
@using System.Security.Cryptography.X509Certificates
@rendermode InteractiveServer

<PageTitle>Home Page</PageTitle>

<h1>Hello, world!</h1>

Welcome to your new app.

@code{ 
    public static int randomInt()
    {
        return new Random().Next(1, 10);
    }
    int r = randomInt();
    private string datetext = "Who cares?";
    private void DateToday()
    {
        datetext = DateTime.Now.ToShortDateString();
    }

    List<char> alph = new List<char>();

    private void GenerateAlphabet()
    {
        alph.Clear();
        Random rand = new Random();
        int count = rand.Next(1, 26);
        for (int i = 0; i < count; i++)
        {
            alph.Add((char)('A' + i));
        }
    }

    List<int> randomNumbers = new List<int>();
    protected override void OnInitialized()
    {
        Random randy = new Random();
        int count = randy.Next(1,10);
        for (int i = 0; i < count; i++)
        {
            randomNumbers.Add(randy.Next(1, 50));
        }
    }
    
}
    
<p>Current num: @r</p>

<button @onclick="DateToday">What's today?</button>
<p>@datetext</p>

<button @onclick="GenerateAlphabet">Generate Alphabet</button>

@if (alph.Count > 0)
{
    <ol>
        @foreach (var letter in alph)
        {
            <li>@letter</li>
        }
    </ol>
}

<h3>Random Numbers Table</h3>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Number</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var number in randomNumbers)
        {
            <tr>
                <td>@number</td>
            </tr>
        }
    </tbody>
</table>
<Counter IncrementAmount="@r"/>

<Weather/>